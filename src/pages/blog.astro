---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactCTA from '../components/ContactCTA.astro';
import Hero from '../components/Hero.astro';
import Pill from '../components/Pill.astro';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf(),
);
---

<BaseLayout
	title="Blog | Ujjwal Shrestha"
	description="Thoughts on web development, tech in Nepal, and software engineering."
>
	<div class="stack gap-20">
		<main class="wrapper stack gap-8">
			<Hero
				title="Blog"
				tagline="Thoughts on web development, tech in Nepal, and building things that matter."
				align="start"
			/>
			<ul class="post-list">
				{
					posts.map((post) => (
						<li class="post-card">
							<a href={`/blog/${post.id}/`} class="post-link">
								<div class="post-meta">
									<time datetime={post.data.publishDate.toISOString()}>
										{post.data.publishDate.toLocaleDateString('en-US', {
											year: 'numeric',
											month: 'long',
											day: 'numeric',
										})}
									</time>
									<div class="tags">
										{post.data.tags.map((tag) => (
											<Pill>{tag}</Pill>
										))}
									</div>
								</div>
								<h2 class="post-title">{post.data.title}</h2>
								<p class="post-description">{post.data.description}</p>
								<span class="read-more">Read post →</span>
							</a>
						</li>
					))
				}
			</ul>
		</main>
		<ContactCTA />
	</div>
</BaseLayout>

<style>
	.post-list {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
	}

	.post-card {
		border: 1px solid var(--gray-800);
		border-radius: 1rem;
		background: var(--gradient-subtle);
		box-shadow: var(--shadow-sm);
		transition: box-shadow var(--theme-transition), border-color var(--theme-transition);
	}

	.post-card:hover {
		box-shadow: var(--shadow-md);
		border-color: var(--gray-600);
	}

	.post-link {
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
		padding: 1.5rem;
		text-decoration: none;
		color: inherit;
	}

	.post-meta {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 0.75rem;
	}

	time {
		font-size: var(--text-sm);
		color: var(--gray-400);
	}

	.tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.375rem;
	}

	.post-title {
		font-size: var(--text-xl);
		color: var(--gray-0);
		line-height: 1.3;
	}

	.post-description {
		font-size: var(--text-md);
		color: var(--gray-300);
		max-width: 60ch;
	}

	.read-more {
		font-size: var(--text-sm);
		color: var(--accent-regular);
		font-weight: 500;
	}

	@media (min-width: 50em) {
		.post-title {
			font-size: var(--text-2xl);
		}
	}
</style>
