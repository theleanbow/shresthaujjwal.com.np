---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ContactCTA from '../../components/ContactCTA.astro';
import Hero from '../../components/Hero.astro';
import Icon from '../../components/Icon.astro';
import Pill from '../../components/Pill.astro';

interface Props {
	entry: CollectionEntry<'blog'>;
}

export async function getStaticPaths() {
	const posts = await getCollection('blog');
	return posts.map((entry) => ({
		params: { slug: entry.id },
		props: { entry },
	}));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const wordCount = entry.body?.split(/\s+/).length ?? 0;
const readingTime = Math.max(1, Math.ceil(wordCount / 200));
---

<BaseLayout title={entry.data.title} description={entry.data.description}>
	<div class="progress-bar" id="progress-bar" aria-hidden="true"></div>

	<div class="stack gap-20">
		<div class="stack gap-15">
			<header>
				<div class="wrapper stack gap-2">
					<a class="back-link" href="/blog/"><Icon icon="arrow-left" /> Blog</a>
					<Hero title={entry.data.title} align="start">
						<div class="details">
							<div class="tags">
								{entry.data.tags.map((t) => <Pill>{t}</Pill>)}
							</div>
							<p class="description">{entry.data.description}</p>
							<div class="meta-row">
								<time class="publish-date" datetime={entry.data.publishDate.toISOString()}>
									{entry.data.publishDate.toLocaleDateString('en-US', {
										year: 'numeric',
										month: 'long',
										day: 'numeric',
									})}
								</time>
								<span class="reading-time">
									<Icon icon="pencil-line" size="0.9em" />
									{readingTime} min read
								</span>
							</div>
						</div>
					</Hero>
				</div>
			</header>

			<main class="wrapper">
				<div class="content-wrap">
					<article class="content">
						{entry.data.img && <img src={entry.data.img} alt={entry.data.img_alt || ''} />}
						<Content />
					</article>
				</div>
			</main>
		</div>
		<ContactCTA />
	</div>
</BaseLayout>

<script>
	const bar = document.getElementById('progress-bar');
	if (bar) {
		window.addEventListener('scroll', () => {
			const doc = document.documentElement;
			const pct = doc.scrollTop / (doc.scrollHeight - doc.clientHeight);
			bar.style.width = `${Math.min(pct * 100, 100)}%`;
		}, { passive: true });
	}
</script>

<style>
	/* ── Progress bar ── */
	.progress-bar {
		position: fixed;
		top: 0;
		left: 0;
		height: 3px;
		width: 0%;
		background: var(--gradient-accent);
		z-index: 1000;
		transition: width 0.1s linear;
		border-radius: 0 2px 2px 0;
	}

	/* ── Header ── */
	header {
		padding-bottom: 2.5rem;
		border-bottom: 1px solid var(--gray-800);
	}

	.back-link {
		display: none;
	}

	.details {
		display: flex;
		flex-direction: column;
		padding: 0.5rem;
		gap: 1rem;
		align-items: flex-start;
	}

	.tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
	}

	.description {
		font-size: var(--text-lg);
		max-width: 54ch;
	}

	.meta-row {
		display: flex;
		align-items: center;
		gap: 1rem;
		flex-wrap: wrap;
	}

	.publish-date {
		font-size: var(--text-sm);
		color: var(--gray-400);
	}

	.reading-time {
		display: flex;
		align-items: center;
		gap: 0.35rem;
		font-size: var(--text-sm);
		color: var(--gray-400);
		padding: 0.2rem 0.65rem;
		border: 1px solid var(--gray-800);
		border-radius: 999rem;
		background: var(--gradient-subtle);
	}

	/* ── Content wrapper ── */
	.content-wrap {
		max-width: 74ch;
		margin-inline: auto;
	}

	/* ── Base prose ── */
	.content :global(* + *) {
		margin-top: 1.25rem;
	}

	.content :global(p) {
		font-size: var(--text-md);
		line-height: 1.85;
		color: var(--gray-300);
	}

	/* ── Section headings (h2) — full-width accent bar ── */
	.content :global(h2) {
		position: relative;
		font-size: var(--text-2xl);
		color: var(--gray-0);
		margin-top: 4rem;
		margin-bottom: 1.25rem;
		padding: 0.75rem 1rem 0.75rem 1.25rem;
		background: var(--gradient-subtle);
		border: 1px solid var(--gray-800);
		border-left: 4px solid var(--accent-regular);
		border-radius: 0 0.5rem 0.5rem 0;
		box-shadow: var(--shadow-sm);
	}

	/* ── Sub-headings (h3) — pricing section cards ── */
	.content :global(h3) {
		font-size: var(--text-xl);
		color: var(--gray-0);
		margin-top: 2.5rem;
		margin-bottom: 0.25rem;
	}

	/* Price badge — first <strong> right after an h3 */
	.content :global(h3 + p > strong:first-child) {
		display: inline-block;
		font-size: var(--text-md);
		font-weight: 700;
		color: var(--gray-0);
		background: var(--gradient-subtle);
		border: 1px solid var(--gray-800);
		border-radius: 0.4rem;
		padding: 0.2rem 0.8rem;
		margin-bottom: 0.5rem;
	}

	.content :global(h4),
	.content :global(h5) {
		margin-top: 1.5rem;
		margin-bottom: 0.5rem;
		color: var(--gray-100);
	}

	/* ── Blockquote ── */
	.content :global(blockquote) {
		font-size: var(--text-lg);
		font-family: var(--font-brand);
		font-weight: 500;
		line-height: 1.6;
		padding: 1.5rem 1.75rem;
		border-left: 4px solid var(--accent-regular);
		background: var(--gradient-subtle);
		border-radius: 0 0.75rem 0.75rem 0;
		color: var(--gray-0);
		margin: 2.5rem 0;
		box-shadow: var(--shadow-md);
	}

	/* ── Lists ── */
	.content :global(ul) {
		padding: 1.25rem 1.5rem;
		background: var(--gradient-subtle);
		border: 1px solid var(--gray-800);
		border-radius: 0.75rem;
		display: flex;
		flex-direction: column;
		gap: 0.6rem;
		box-shadow: var(--shadow-sm);
	}

	.content :global(ol) {
		padding-inline-start: 1.5rem;
		display: flex;
		flex-direction: column;
		gap: 0.6rem;
	}

	.content :global(li) {
		font-size: var(--text-md);
		line-height: 1.7;
		color: var(--gray-200);
	}

	.content :global(li > strong:first-child) {
		color: var(--gray-0);
	}

	/* ── Dividers ── */
	.content :global(hr) {
		border: none;
		border-top: 1px solid var(--gray-800);
		margin: 3.5rem 0;
	}

	.content :global(strong) {
		color: var(--gray-100);
		font-weight: 600;
	}

	/* ── Tables ── */
	.content :global(table) {
		width: 100%;
		border-collapse: collapse;
		font-size: var(--text-sm);
		margin: 2rem 0;
		border-radius: 0.75rem;
		overflow: hidden;
		box-shadow: var(--shadow-md);
		border: 1px solid var(--gray-800);
	}

	.content :global(th),
	.content :global(td) {
		padding: 0.75rem 1.25rem;
		border-bottom: 1px solid var(--gray-800);
		text-align: left;
	}

	.content :global(td:not(:last-child)),
	.content :global(th:not(:last-child)) {
		border-right: 1px solid var(--gray-800);
	}

	.content :global(th) {
		background: var(--gradient-accent);
		color: var(--accent-text-over);
		font-weight: 600;
		font-size: var(--text-sm);
		letter-spacing: 0.05em;
		text-transform: uppercase;
	}

	.content :global(tr:last-child td) {
		border-bottom: none;
	}

	.content :global(tr:nth-child(even) td) {
		background: var(--gradient-subtle);
	}

	.content :global(tr:hover td) {
		background: var(--accent-subtle-overlay);
	}

	/* ── Images ── */
	.content :global(img) {
		border-radius: 1.5rem;
		box-shadow: var(--shadow-md);
		background: var(--gradient-subtle);
		border: 1px solid var(--gray-800);
	}

	/* ── Links ── */
	.back-link,
	.content :global(a) {
		text-decoration: 1px solid underline transparent;
		text-underline-offset: 0.25em;
		transition: text-decoration-color var(--theme-transition);
	}

	.back-link:hover,
	.back-link:focus,
	.content :global(a:hover),
	.content :global(a:focus) {
		text-decoration-color: currentColor;
	}

	@media (min-width: 50em) {
		.back-link {
			display: block;
			align-self: flex-start;
		}

		.content :global(blockquote) {
			font-size: var(--text-xl);
		}

		.content :global(h2) {
			font-size: var(--text-3xl);
		}
	}
</style>
