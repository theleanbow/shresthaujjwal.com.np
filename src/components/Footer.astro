---
import Icon from './Icon.astro';

const currentYear = new Date().getFullYear();
---

<footer>
	<div class="wrapper footer-inner">
		<p class="copyright">&copy; {currentYear} Ujjwal Shrestha</p>

		<div class="socials">
			<a href="https://www.linkedin.com/in/ujjwalstha" aria-label="LinkedIn" target="_blank" rel="noopener">
				<Icon icon="linkedin-logo" size="1.2em" />
			</a>
			<a href="https://github.com/theleanbow" aria-label="GitHub" target="_blank" rel="noopener">
				<Icon icon="github-logo" size="1.2em" />
			</a>
			<a href="mailto:ujjwal72486@gmail.com" aria-label="Email">
				<Icon icon="paper-plane-tilt" size="1.2em" />
			</a>
		</div>

		<p class="credit">Designed & built with <a href="https://astro.build/" target="_blank" rel="noopener">Astro</a></p>
	</div>
</footer>

<style>
	footer {
		border-top: 1px solid var(--gray-800);
		padding-block: 2.5rem;
		color: var(--gray-400);
		font-size: var(--text-md);
	}

	.footer-inner {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 1.5rem;
		text-align: center;
	}

	.socials {
		display: flex;
		gap: 0.5rem;
	}

	.socials a {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 3.25rem;
		height: 3.25rem;
		border-radius: 50%;
		border: 1px solid var(--gray-800);
		color: var(--gray-300);
		text-decoration: none;
		font-size: 1.5rem;
		transition: color var(--theme-transition), border-color var(--theme-transition);
	}

	.socials a:hover {
		color: var(--gray-0);
		border-color: var(--gray-600);
	}

	.credit a {
		color: inherit;
		text-decoration: none;
		transition: color var(--theme-transition);
	}

	.credit a:hover {
		color: var(--gray-0);
	}

	@media (min-width: 50em) {
		.footer-inner {
			flex-direction: row;
			justify-content: space-between;
			text-align: left;
		}
	}
</style>
